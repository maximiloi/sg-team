# =================================================================
# Переменные окружения для Super Garage Team
# =================================================================
# Скопируйте этот файл в .env и заполните значениями
# cp .env.example .env
# =================================================================

# -----------------------------------------------------------------
# База данных (PostgreSQL)
# -----------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/post_db"

# -----------------------------------------------------------------
# NextAuth (Аутентификация)
# -----------------------------------------------------------------
# URL вашего приложения (без слэша в конце)
NEXTAUTH_URL="http://localhost:3000"

# Секретный ключ для подписи JWT токенов
# Сгенерируйте командой: openssl rand -base64 32
# Или: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="your-secret-key-here-replace-with-secure-random-string"

# -----------------------------------------------------------------
# Telegram Bot (уведомления)
# -----------------------------------------------------------------
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN="your-bot-token-here"

# ID менеджеров, которые получают уведомления (через запятую)
# Узнать свой ID можно через бота @userinfobot
TELEGRAM_MANAGER_IDS="123456789,987654321"

# -----------------------------------------------------------------
# Продакшн (PM2)
# -----------------------------------------------------------------
PORT=3002
HOST=127.0.0.1
NODE_ENV=production
